# Ignore everything in the repo by default
/*

# But keep this .gitignore file
!.gitignore

# Keep the Confocale folder itself so we can selectively include files inside it
!/Confocale/

# Inside Confocale, ignore everything by default
/Confocale/*

# Allow only these Python files in Confocale
!/Confocale/tamsd_plot.py
!/Confocale/data_reader.py
!/Confocale/msd_analyzer.py
!/Confocale/eamsd_plot.py
!/Confocale/guide.md
!/Confocale/compare_msd.py
!/Confocale/plot_msd_fit.py
!/Confocale/msd_fitting.py
!/Confocale/msd_fitting_nonlinear.py
!/Confocale/msd_fitting_anomalous.py
!/Confocale/msd_fitting_anomalous_drift.py

# Keep the Docu folder itself so we can selectively include files inside it
!/Confocale/Docu/
# Allow only these files in Docu
!Confocale//Docu/COMPLETE_USER_GUIDE.md
!Confocale/Docu/OVERVIEW.md
!Confocale/Docu/DATA_ANALYSIS_CORE.md
!Confocale/Docu/COMPARISON_ANALYSIS.md
!Confocale/Docu/MSD_FITTING.md
!Confocale/Docu/SCRIPTS_REFERENCE.md
!Confocale/Docu/GETTING_STARTED_BEGINNERS.md